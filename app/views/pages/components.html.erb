<% content_for :head do %>
  <%= stylesheet_link_tag "components", "data-turbo-track": "reload" %>
<% end %>

<section class="components-page">
  <header class="components-hero">
    <div class="components-hero__copy">
      <span class="components-eyebrow">Designsystem</span>
      <h1>Komponenten fuer den Finanz Tracker</h1>
      <p>
        Diese Uebersicht sammelt typische UI-Bausteine fuer Dashboard, Buchungen und spaetere
        Verwaltungsseiten. Der Fokus liegt auf klaren Finanzkennzahlen, ruhigen Oberflaechen und
        schnellen Aktionen.
      </p>
    </div>

    <aside class="components-hero__panel">
      <span class="components-panel__label">Empfohlene Richtung</span>
      <ul class="components-checklist">
        <li>KPI-Karten mit klarer Zahl und kurzer Entwicklung</li>
        <li>sekundaere Links eher als Text oder Chips statt als Primarbutton</li>
        <li>Formulare kompakt, aber nicht eng</li>
        <li>Kategorien als farbige Tags statt Fliesstext</li>
        <li>Top-Ausgaben visuell staerker hervorheben</li>
      </ul>
    </aside>
  </header>

  <section class="component-section">
    <div class="component-section__heading">
      <span class="component-section__eyebrow">Links</span>
      <h2>Navigations- und Aktionslinks</h2>
      <p>Geeignet fuer Uebersichten, Detailwechsel und sekundaere Navigation.</p>
    </div>

    <div class="component-grid component-grid--links">
      <a class="component-link-card" href="#">
        <span class="component-link-card__label">Zu den Buchungen</span>
        <strong>Alle Bewegungen ansehen</strong>
        <small>Monat, Konto und Kategorien filtern</small>
      </a>

      <a class="component-link-card" href="#">
        <span class="component-link-card__label">Zur Kategorieanalyse</span>
        <strong>Top-Kategorien oeffnen</strong>
        <small>Ausgaben nach Themenclustern auswerten</small>
      </a>

      <a class="component-link-card" href="#">
        <span class="component-link-card__label">Zum Konto</span>
        <strong>Girokonto Pruefung</strong>
        <small>Saldo, letzte Buchungen und Abweichungen</small>
      </a>

      <a class="component-link-card" href="#">
        <span class="component-link-card__label">Zum Import</span>
        <strong>CSV-Daten pruefen</strong>
        <small>Neue Umsaetze gegen bestehende Daten abgleichen</small>
      </a>

      <a class="component-link-card" href="#">
        <span class="component-link-card__label">Zur Planung</span>
        <strong>Monatsbudget vergleichen</strong>
        <small>Budget und Ist-Werte je Kategorie betrachten</small>
      </a>
    </div>
  </section>

  <section class="component-section">
    <div class="component-section__heading">
      <span class="component-section__eyebrow">Buttons</span>
      <h2>Primaere und sekundaere Aktionen</h2>
      <p>Die Beispiele decken typische Aufgaben aus Erfassung, Review und Verwaltung ab.</p>
    </div>

    <div class="button-showcase">
      <button class="component-button component-button--primary" type="button">Neue Buchung</button>
      <button class="component-button component-button--secondary" type="button">Monatsbericht exportieren</button>
      <button class="component-button component-button--soft" type="button">Filter zuruecksetzen</button>
      <button class="component-button component-button--ghost" type="button">Kategorien verwalten</button>
      <button class="component-button component-button--danger" type="button">Buchung loeschen</button>
    </div>
  </section>

  <section class="component-section">
    <div class="component-section__heading">
      <span class="component-section__eyebrow">Formulare</span>
      <h2>Fuenf Formularmuster fuer Buchungen und Filter</h2>
      <p>Die Felder sind bewusst als statische Beispiele aufgebaut und nicht an ein Modell gebunden.</p>
    </div>

    <div class="component-grid component-grid--forms">
      <form class="component-form">
        <h3>Schnelle Ausgabe</h3>
        <label>
          Beschreibung
          <input type="text" value="Supermarkt" />
        </label>
        <label>
          Betrag
          <input type="text" value="-42,80 EUR" />
        </label>
        <label>
          Kategorie
          <select>
            <option>Lebensmittel</option>
          </select>
        </label>
      </form>

      <form class="component-form">
        <h3>Einnahme erfassen</h3>
        <label>
          Quelle
          <input type="text" value="Gehalt April" />
        </label>
        <label>
          Betrag
          <input type="text" value="2.950,00 EUR" />
        </label>
        <label>
          Konto
          <select>
            <option>Girokonto</option>
          </select>
        </label>
      </form>

      <form class="component-form">
        <h3>Monatsfilter</h3>
        <label>
          Monat
          <input type="month" value="2026-04" />
        </label>
        <label>
          Konto
          <select>
            <option>Alle Konten</option>
          </select>
        </label>
        <label>
          Typ
          <select>
            <option>Alle Buchungen</option>
          </select>
        </label>
      </form>

      <form class="component-form">
        <h3>Kategorievergleich</h3>
        <label>
          Kategorie 1
          <select>
            <option>Wohnen</option>
          </select>
        </label>
        <label>
          Kategorie 2
          <select>
            <option>Freizeit</option>
          </select>
        </label>
        <label>
          Zeitraum
          <input type="text" value="Jan 2026 - Apr 2026" />
        </label>
      </form>

      <form class="component-form">
        <h3>Import pruefen</h3>
        <label>
          Datei
          <input type="text" value="umsatz_april.csv" />
        </label>
        <label>
          Konto zuordnen
          <select>
            <option>Tagesgeld</option>
          </select>
        </label>
        <label>
          Dublettenregel
          <select>
            <option>Gleicher Betrag und gleiches Datum</option>
          </select>
        </label>
      </form>
    </div>
  </section>

  <section class="component-section">
    <div class="component-section__heading">
      <span class="component-section__eyebrow">Karten</span>
      <h2>Informationskarten fuer Listen, Konten und Warnungen</h2>
      <p>Diese Karten zeigen verschiedene Gewichtungen zwischen Zahl, Kontext und Handlung.</p>
    </div>

    <div class="component-grid component-grid--cards">
      <article class="component-card">
        <span class="component-card__tag">Buchung</span>
        <h3>Supermarkt am 01.04.</h3>
        <p>Girokonto, Lebensmittel, wiederkehrendes Muster erkennbar.</p>
        <strong>-42,80 EUR</strong>
      </article>

      <article class="component-card">
        <span class="component-card__tag">Konto</span>
        <h3>Girokonto Hauptkonto</h3>
        <p>Solide Liquiditaet, letzte groessere Bewegung vor drei Tagen.</p>
        <strong>3.842,10 EUR</strong>
      </article>

      <article class="component-card">
        <span class="component-card__tag">Warnung</span>
        <h3>Freizeitbudget fast erreicht</h3>
        <p>89 Prozent des Monatsbudgets sind bereits genutzt.</p>
