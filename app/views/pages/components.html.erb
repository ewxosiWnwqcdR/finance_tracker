          </div>

          <div class="category-ranking__item">
            <div class="category-ranking__meta">
              <span>Lebensmittel</span>
              <strong>368,40 EUR</strong>
            </div>
            <div class="category-ranking__bar"><span style="width: 31%"></span></div>
          </div>

          <div class="category-ranking__item">
            <div class="category-ranking__meta">
              <span>Mobilitaet</span>
              <strong>214,00 EUR</strong>
            </div>
            <div class="category-ranking__bar"><span style="width: 18%"></span></div>
          </div>
        </div>
      </article>

      <article class="kpi-list-card">
        <div class="kpi-list-card__head">
          <span class="kpi-card__label">Kontostand nach Konto</span>
